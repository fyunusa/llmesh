{
    "name": "llmesh/core",
    "description": "LLMesh Core - A flexible PHP SDK for interacting with multiple LLM providers",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "php",
        "ai",
        "llm",
        "openai",
        "anthropic",
        "sdk"
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-client": "^1.0",
        "psr/log": "^3.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "mockery/mockery": "^1.6",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "suggest": {
        "ext-redis": "Required to use RedisStore for memory storage",
        "predis/predis": "Alternative Redis client library for RedisStore",
        "ext-pdo_pgsql": "Required if using PostgreSQL/pgvector for vector storage"
    },
    "autoload": {
        "psr-4": {
            "LLMesh\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LLMesh\\Core\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-clover coverage/coverage.xml --coverage-html coverage",
        "lint": "vendor/bin/phpcs src tests --standard=PSR12"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/llmesh"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}

