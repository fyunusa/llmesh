{
    "name": "llmesh/core",
    "description": "LLMesh Core - A flexible PHP SDK for interacting with multiple LLM providers",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-client": "^1.0",
        "psr/log": "^3.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "mockery/mockery": "^1.6",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "LLMesh\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LLMesh\\Core\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage",
        "lint": "vendor/bin/phpcs src tests --standard=PSR12"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
